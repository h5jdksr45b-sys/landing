  // ====== UI ======
  const elApp = document.getElementById("app");
  const elQ = document.getElementById("q");
  const elFilters = document.getElementById("filters");
  const toast = document.getElementById("toast");
  const toastText = document.getElementById("toastText");

  const cats = [...new Set(PROMPTS.map(p => p.cat))];

  const state = { q:"", cat:"Todas" };

  function showToast(msg){
    toastText.textContent = msg;
    toast.classList.add("show");
    clearTimeout(showToast._t);
    showToast._t = setTimeout(() => toast.classList.remove("show"), 1400);
  }

  async function copyText(text){
    try{
      await navigator.clipboard.writeText(text);
      showToast("Copiado ✅");
    }catch(e){
      // fallback
      const ta = document.createElement("textarea");
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand("copy");
      ta.remove();
      showToast("Copiado ✅");
    }
  }

  function buildFilters(){
    const all = ["Todas", ...cats];
    elFilters.innerHTML = "";
    all.forEach(name=>{
      const b = document.createElement("div");
      b.className = "pill" + (state.cat===name ? " active": "");
      b.textContent = name;
      b.onclick = ()=>{ state.cat=name; render(); buildFilters(); };
      elFilters.appendChild(b);
    });
  }

  function groupByCategory(list){
    const map = new Map();
    list.forEach(p=>{
      if(!map.has(p.cat)) map.set(p.cat, []);
      map.get(p.cat).push(p);
    });
    return map;
  }

  function match(p, q){
    if(!q) return true;
    const s = (p.title + " " + p.meta + " " + p.text).toLowerCase();
    return s.includes(q.toLowerCase());
  }

  function render(){
    const filtered = PROMPTS
      .filter(p => (state.cat==="Todas" ? true : p.cat===state.cat))
      .filter(p => match(p, state.q));

    const grouped = groupByCategory(filtered);

    elApp.innerHTML = "";
    const order = (state.cat==="Todas") ? cats : [state.cat];

    order.forEach(cat=>{
      const items = grouped.get(cat) || [];
      if(!items.length) return;

      const catEl = document.createElement("section");
      catEl.className = "cat open";

      const head = document.createElement("div");
      head.className = "catHead";
      head.innerHTML = `
        <div class="left">
          <span class="badge">${cat}</span>
          <span class="name"></span>
        </div>
        <div class="count">${items.length} prompt(s)</div>
      `;
      head.querySelector(".name").textContent = "";

      head.onclick = ()=>catEl.classList.toggle("open");

      const body = document.createElement("div");
      body.className = "catBody";

      const cards = document.createElement("div");
      cards.className = "cards";

      items.forEach(p=>{
        const card = document.createElement("div");
        card.className = "card";

        const top = document.createElement("div");
        top.className = "cardTop";

        const left = document.createElement("div");
        left.innerHTML = `
          <div class="cardTitle">${p.title}</div>
          <div class="cardMeta">${p.meta || ""}</div>
        `;

        const btnrow = document.createElement("div");
        btnrow.className = "btnrow";

        const btnCopy = document.createElement("button");
        btnCopy.className = "copyBtn";
        btnCopy.textContent = "Copiar";
        btnCopy.onclick = (e)=>{ e.stopPropagation(); copyText(p.text); };

        const btnView = document.createElement("button");
        btnView.className = "viewBtn";
        btnView.textContent = "Ver";
        btnView.onclick = (e)=>{ e.stopPropagation(); card.classList.toggle("open"); };

        btnrow.appendChild(btnCopy);
        btnrow.appendChild(btnView);

        top.appendChild(left);
        top.appendChild(btnrow);

        const pre = document.createElement("pre");
        pre.textContent = p.text;

        card.appendChild(top);
        card.appendChild(pre);
        cards.appendChild(card);
      });

      body.appendChild(cards);
      catEl.appendChild(head);
      catEl.appendChild(body);
      elApp.appendChild(catEl);
    });

    if(!filtered.length){
      const empty = document.createElement("div");
      empty.className = "cat";
      empty.innerHTML = `<div class="catHead"><div class="left"><span class="badge">Sem resultados</span><span class="name"></span></div><div class="count">0</div></div>
      <div class="catBody" style="display:block; color:var(--muted); padding:14px;">Tente outra busca (ex: "Suno", "gancho", "tabela", "indignação").</div>`;
      elApp.appendChild(empty);
    }
  }

  elQ.addEventListener("input", (e)=>{ state.q = e.target.value.trim(); render(); });

  buildFilters();
  render();
</script>
