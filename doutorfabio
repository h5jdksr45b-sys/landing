<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Biblioteca de Prompts — Dr. Fábio Schmidt</title>
  <style>
    :root{
      --bg:#0b0f14; --panel:#101826; --panel2:#0f1724; --text:#e8eef7; --muted:#a7b3c6;
      --brand:#7aa2ff; --ok:#2ee59d; --warn:#ffcc66; --danger:#ff6b6b; --line:#223047;
    }
    *{box-sizing:border-box}
    body{
      margin:0; background:linear-gradient(180deg,#070a0f, #0b0f14 20%, #0b0f14);
      color:var(--text); font:15px/1.4 system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;
    }
    header{
      position:sticky; top:0; z-index:50;
      backdrop-filter: blur(10px);
      background:rgba(11,15,20,.75);
      border-bottom:1px solid rgba(34,48,71,.7);
    }
    .wrap{max-width:1100px; margin:0 auto; padding:18px 16px;}
    .title{
      display:flex; gap:12px; align-items:flex-start; justify-content:space-between; flex-wrap:wrap;
    }
    h1{margin:0; font-size:18px; letter-spacing:.2px}
    .sub{margin:4px 0 0; color:var(--muted); font-size:13px}
    .toolbar{
      display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin-top:14px;
    }
    .search{
      flex:1 1 360px; min-width:240px;
      display:flex; gap:10px; align-items:center;
      background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:10px 12px;
    }
    .search input{
      width:100%; background:transparent; border:0; outline:0; color:var(--text);
      font-size:14px;
    }
    .pillrow{display:flex; gap:8px; flex-wrap:wrap}
    .pill{
      border:1px solid var(--line); background:var(--panel);
      color:var(--muted); padding:8px 10px; border-radius:999px; cursor:pointer;
      font-size:13px; user-select:none;
    }
    .pill.active{border-color:rgba(122,162,255,.65); color:var(--text); box-shadow:0 0 0 2px rgba(122,162,255,.15) inset}
    main .wrap{padding-top:14px; padding-bottom:40px;}
    .grid{
      display:grid; grid-template-columns: 1fr; gap:12px;
    }
    .cat{
      background:linear-gradient(180deg,var(--panel),var(--panel2));
      border:1px solid var(--line); border-radius:16px; overflow:hidden;
    }
    .catHead{
      display:flex; align-items:center; justify-content:space-between; gap:12px;
      padding:14px 14px; cursor:pointer; user-select:none;
      border-bottom:1px solid rgba(34,48,71,.7);
    }
    .catHead .left{
      display:flex; gap:10px; align-items:center;
    }
    .badge{
      font-size:12px; padding:4px 10px; border-radius:999px;
      border:1px solid rgba(122,162,255,.35); color:var(--text); background:rgba(122,162,255,.08);
    }
    .catHead .name{font-weight:700}
    .catHead .count{color:var(--muted); font-size:13px}
    .catBody{display:none; padding:12px 12px 14px;}
    .cat.open .catBody{display:block}
    .cards{
      display:grid; grid-template-columns:repeat(12,1fr); gap:10px;
    }
    .card{
      grid-column: span 12;
      background:rgba(8,12,18,.55);
      border:1px solid rgba(34,48,71,.7);
      border-radius:14px; padding:12px;
    }
    @media (min-width: 860px){
      .card{grid-column: span 6;}
    }
    .cardTop{
      display:flex; align-items:flex-start; justify-content:space-between; gap:10px;
      margin-bottom:10px;
    }
    .cardTitle{font-weight:700; margin:0; font-size:14px}
    .cardMeta{color:var(--muted); font-size:12px; margin-top:3px}
    .btnrow{display:flex; gap:8px; flex-wrap:wrap}
    button{
      border:1px solid rgba(34,48,71,.95);
      background:rgba(16,24,38,.85);
      color:var(--text);
      padding:8px 10px; border-radius:10px; cursor:pointer; font-size:13px;
    }
    button:hover{border-color:rgba(122,162,255,.65)}
    .copyBtn{border-color:rgba(46,229,157,.35)}
    .copyBtn:hover{border-color:rgba(46,229,157,.75)}
    .viewBtn{border-color:rgba(122,162,255,.35)}
    .dangerBtn{border-color:rgba(255,107,107,.35)}
    pre{
      margin:0; padding:12px;
      background:#070b12; border:1px solid rgba(34,48,71,.7);
      border-radius:12px;
      color:#e6f0ff; overflow:auto; white-space:pre-wrap; word-wrap:break-word;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size:12.8px; line-height:1.35;
      display:none;
    }
    .card.open pre{display:block}
    .toast{
      position:fixed; bottom:18px; left:50%; transform:translateX(-50%);
      background:rgba(16,24,38,.92);
      border:1px solid rgba(34,48,71,.9);
      padding:10px 12px; border-radius:12px; color:var(--text);
      box-shadow:0 10px 30px rgba(0,0,0,.35);
      display:none; align-items:center; gap:10px;
      max-width:92vw;
    }
    .toast .dot{width:10px; height:10px; border-radius:999px; background:var(--ok)}
    .toast.show{display:flex}
    footer{color:var(--muted); font-size:12px; padding:18px 16px 40px; text-align:center}
    .kbd{font-family:ui-monospace,Menlo,Consolas,monospace; border:1px solid rgba(34,48,71,.9); background:rgba(16,24,38,.7); padding:2px 6px; border-radius:7px; color:var(--text)}
  </style>
</head>
